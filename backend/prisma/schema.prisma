generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Statusi {
  aktiv
  joaktiv
}

model User {
  id                  Int             @id @default(autoincrement())
  emri                String
  mbiemri             String
  email               String          @unique
  password_hash       String
  phone_number        String?
  email_confirmed     Boolean         @default(false)
  lockout_enabled     Boolean         @default(false)
  access_failed_count Int             @default(0)
  data_krijimit       DateTime        @default(now())
  statusi             Statusi         @default(aktiv)

  userRoles     UserRole[]
  userClaims    UserClaim[]
  userTokens    UserToken[]
  refreshTokens RefreshToken[]
}

model Role {
  id              Int        @id @default(autoincrement())
  emertimi        String
  pershkrimi      String?
  normalized_name String     @unique

  userRoles UserRole[]
}

model UserRole {
  id      Int  @id @default(autoincrement())
  user_id Int
  role_id Int

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id]) 
}

model UserClaim {
  id          Int    @id @default(autoincrement())
  user_id     Int
  claim_type  String
  claim_value String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model UserToken {
  id             Int    @id @default(autoincrement())
  user_id        Int
  login_provider String
  token_name     String
  token_value    String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id       Int      @id @default(autoincrement())
  user_id  Int
  token    String   @unique
  expires  DateTime
  created  DateTime @default(now())
  revoked  DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}